    {
      "name": "AddCallback",
      "group": "Core",
      "description": "Adds a callback to existing hook",
      "funcName": "AddCallback",
      "paramTypes": [
        {
          "type": "ptr64",
          "name": "hook",
          "description": "Hook pointer"
        },
        {
          "type": "bool",
          "name": "post",
          "description": "True indicates post hook"
        },
        {
          "type": "function",
          "name": "handler",
          "description": "Callback function which trigger by hook.",
          "prototype": {
            "name": "CallbackHandler",
            "funcName": "CallbackHandler",
            "paramTypes": [
              {
                "type": "bool",
                "name": "post",
                "description": "True indicates post hook"
              },
              {
                "type": "ptr64",
                "name": "params",
                "description": "Pointer to params structure"
              },
              {
                "type": "int32",
                "name": "count",
                "description": "Parameter count"
              },
              {
                "type": "ptr64",
                "name": "ret",
                "description": "Pointer to return structure"
              }
            ],
            "retType": {
              "type": "int32",
              "description": "Ignored = Handler didn't take any action\nHandled = We did something, but real function should still be called\nOverride = Call real function, but use my return value\nSupercede = Skip real function; use my return value\nIgnored for post hooks."
            }
          }
        }
      ],
      "retType": {
        "type": "bool",
        "description": "Returns true on success, false otherwise"
      }
    },
    {
